{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "allowJs": true,
    "checkJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": false,
    "declaration": true,
    "outDir": "lib",
    "sourceMap": true,
    "moduleResolution": "node"
  },
  "types": ["node"],
  "include": [ "src" ],
  "exclude": ["node_modules", "lib"]
}
