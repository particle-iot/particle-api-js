{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "allowJs": false,
    "checkJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": true,
    "noEmit": true,
    "types": ["node", "mocha", "chai", "chai-subset"]
  },
  "include": ["src", "test"],
  "exclude": ["node_modules"]
}
